FROM golang:1.23-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG VERSION=dev
RUN CGO_ENABLED=0 go build -ldflags "-s -w -X main.version=${VERSION}" -o /proxy-agent ./cmd/agent

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /proxy-agent /proxy-agent
ENTRYPOINT ["/proxy-agent"]

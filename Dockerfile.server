FROM golang:1.23-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG VERSION=dev
RUN CGO_ENABLED=0 go build -ldflags "-s -w -X main.version=${VERSION}" -o /proxy-server ./cmd/server

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /proxy-server /proxy-server
ENTRYPOINT ["/proxy-server"]
